  <UsingTask TaskName="CleanupCentralLocationTask" TaskFactory="RoslynCodeTaskFactory" AssemblyFile="$(MSBuildToolsPath)\Microsoft.Build.Tasks.Core.dll">
    <!--
         -   ___ _                         ___         _            _ _                 _   _        _____        _   
         -  / __| |___ __ _ _ _ _  _ _ __ / __|___ _ _| |_ _ _ __ _| | |   ___  __ __ _| |_(_)___ _ |_   _|_ _ __| |__
         - | (__| / -_) _` | ' \ || | '_ \ (__/ -_) ' \  _| '_/ _` | | |__/ _ \/ _/ _` |  _| / _ \ ' \| |/ _` (_-< / /
         -  \___|_\___\__,_|_||_\_,_| .__/\___\___|_||_\__|_| \__,_|_|____\___/\__\__,_|\__|_\___/_||_|_|\__,_/__/_\_\
         -                          |_|                                                                               

         Task to clean up obsolete files in the central location.
         Parameters:
           - CentralPath: The path to the central location.
           - ProjectItems: The items from the project to compare against.
           - ExcludePatterns: Optional patterns to exclude from deletion.
      -->
    <ParameterGroup>
      <CentralPath ParameterType="System.String" Required="true" />
      <ProjectItems ParameterType="Microsoft.Build.Framework.ITaskItem[]" Required="true" />
      <ExcludePatterns ParameterType="System.String[]" Required="false" />
    </ParameterGroup>
    <Task>
      <Using Namespace="System" />
      <Using Namespace="System.IO" />
      <Using Namespace="System.Linq" />
      <Using Namespace="System.Collections.Generic" />
      <Code Type="Fragment" Language="cs"><![CDATA[
  try
  {
      // Get all source files from project
      var projectFiles = ProjectItems
          .Select(item => item.ItemSpec.Replace(Path.DirectorySeparatorChar, Path.AltDirectorySeparatorChar))
          .ToList();

      // Build exclude list (default + custom patterns)
      var defaultExcludes = new[] { "version.txt", ".gitignore", "packages.config" };
      var excludeList = (ExcludePatterns ?? Array.Empty<string>())
          .Concat(defaultExcludes)
          .ToList();

      // Get all files in central location
      var centralFiles = Directory.GetFiles(CentralPath, "*.*", SearchOption.AllDirectories)
          .Select(f => f.Replace(CentralPath, "").TrimStart(Path.DirectorySeparatorChar, Path.AltDirectorySeparatorChar))
          .Where(f => !excludeList.Any(exclude => f.EndsWith(exclude, StringComparison.OrdinalIgnoreCase)))
          .ToList();

      // Find files that exist in central but not in project
      var obsoleteFiles = centralFiles
          .Where(centralFile => !projectFiles.Any(projFile => 
              string.Equals(projFile, centralFile, StringComparison.OrdinalIgnoreCase)))
          .ToList();

      if (obsoleteFiles.Any())
      {
          Log.LogMessage(MessageImportance.High, "Found {0} obsolete files:", obsoleteFiles.Count);
          foreach (var file in obsoleteFiles)
          {
              var fullPath = Path.Combine(CentralPath, file);
              Log.LogMessage(MessageImportance.High, $"Deleting: {file}");
                          
              try
              {
                  File.Delete(fullPath);
                              
                  // Clean up empty directories
                  var directory = Path.GetDirectoryName(fullPath);
                  while (!string.IsNullOrEmpty(directory) && 
                          directory.StartsWith(CentralPath) && 
                          Directory.Exists(directory) &&
                          !Directory.EnumerateFileSystemEntries(directory).Any())
                  {
                      Directory.Delete(directory);
                      directory = Path.GetDirectoryName(directory);
                  }
              }
              catch (Exception ex)
              {
                  Log.LogWarning($"Failed to delete {file}: {ex.Message}");
              }
          }
      }
      else
      {
          Log.LogMessage(MessageImportance.Normal, "No obsolete files found in central location.");
      }

      return true;
  }
  catch (Exception ex)
  {
      Log.LogError($"Failed to cleanup central location: {ex.Message}");
      return false;
  }
  ]]></Code>
