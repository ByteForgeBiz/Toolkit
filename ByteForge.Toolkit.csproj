       - |_| |_|_\___|\___/| .__/\__,_\__,_|\__\___|
       -                   |_|                      

      Task to update file content based on a regex pattern.
      Parameters:
        - Files: The files to be updated.
        - Pattern: The regex pattern to find in the file.
        - ReplacementText: The text to replace the pattern with.
       -->
    <ParameterGroup>
      <Files ParameterType="Microsoft.Build.Framework.ITaskItem[]" Required="true" />
      <Pattern ParameterType="System.String" Required="true" />
      <ReplacementText ParameterType="System.String" Required="true" />
    </ParameterGroup>
    <Task>
      <Using Namespace="System" />
      <Using Namespace="System.IO" />
      <Using Namespace="System.Text.RegularExpressions" />
      <Code Type="Fragment" Language="cs"><![CDATA[
try
{
    foreach (var file in Files)
    {
        Log.LogMessage(MessageImportance.High, $"Updating version in {Path.GetFileName(file.ItemSpec)}");
        string content = File.ReadAllText(file.ItemSpec);
        content = Regex.Replace(content, Pattern, ReplacementText);
        File.WriteAllText(file.ItemSpec, content);
    }
    return true;
}
catch (Exception ex)
{
    Log.LogError(ex.Message);
    return false;
}
]]></Code>
    </Task>
  </UsingTask>
  <UsingTask TaskName="UpdateSmartVersionTask" TaskFactory="CodeTaskFactory" AssemblyFile="$(MSBuildToolsPath)\Microsoft.Build.Tasks.Core.dll">
    <!--
       -  _   _          _      _       ___                _ __   __          _        _____        _   
       - | | | |_ __  __| |__ _| |_ ___/ __|_ __  __ _ _ _| |\ \ / /__ _ _ __(_)___ _ |_   _|_ _ __| |__
       - | |_| | '_ \/ _` / _` |  _/ -_)__ \ '  \/ _` | '_|  _\ V / -_) '_(_-< / _ \ ' \| |/ _` (_-< / /
       -  \___/| .__/\__,_\__,_|\__\___|___/_|_|_\__,_|_|  \__|\_/\___|_| /__/_\___/_||_|_|\__,_/__/_\_\
       -       |_|                                                                                      

      Task to update the version file based on the result of a file copy operation.
      Parameters:
        - CentralVersionFile: The path to the central version file.
        - RobocopyErrorLevel: The error level returned by the robocopy command.
      -->
    <ParameterGroup>
      <CentralVersionFile ParameterType="System.String" Required="true" />
      <RobocopyErrorLevel ParameterType="System.Int32" Required="true" />
    </ParameterGroup>
    <Task>
      <Using Namespace="System" />
      <Using Namespace="System.IO" />
      <Code Type="Fragment" Language="cs"><![CDATA[
try {
    // Only process if files were actually copied
    bool filesCopied = (RobocopyErrorLevel & 1) != 0;
    if (!filesCopied) {
        Log.LogMessage(MessageImportance.High, "No files were copied, skipping version update");
        return true;
    }

    var versionFileExists = File.Exists(CentralVersionFile);
    Log.LogMessage(MessageImportance.High, "Checking version file: {0}", CentralVersionFile);
                        
    // Create version file if it doesn't exist
    if (!versionFileExists) {
        Log.LogMessage(MessageImportance.High, "Version file does not exist. Creating...");
        File.WriteAllText(CentralVersionFile, "1.0.0");
    }
        
    var oldVersion = File.ReadAllText(CentralVersionFile);
    var parts = oldVersion.Split('.');
    var intMajor = int.Parse(parts[0]);
    var intMinor = int.Parse(parts[1]);
    var intPatch = int.Parse(parts[2]);
                        
    Log.LogMessage(MessageImportance.High, "Current Library Version: {0}", oldVersion);
                        
    // Check if new files were added (robocopy return code 2)
    bool newFilesAdded = (RobocopyErrorLevel & 2) != 0;
                        
    if (newFilesAdded) {
        Log.LogMessage(MessageImportance.High, "New files added to the library. Incrementing Minor.");
        intMinor += 1;
        intPatch  = 0;
    } else {
        Log.LogMessage(MessageImportance.High, "Some files were updated. Incrementing Patch");
        intPatch += 1;
    }
        
    // Correcting version number
    if (intPatch > 49) {
        Log.LogMessage(MessageImportance.High, "Patch would be 50, incrementing Minor.");
        intMinor += 1;
        intPatch  = 0;
    }
        
    if (intMinor > 49) {
        Log.LogMessage(MessageImportance.High, "Minor would be 50, incrementing Major.");
        intMajor += 1;
        intMinor = 0;
        intPatch = 0;
    }
        
    // Updating version file
        
    var newVersion = string.Format("{0}.{1}.{2}.{3:MMdd}", intMajor, intMinor, intPatch, DateTime.Now);
                        
    // Save updated version
    File.WriteAllText(CentralVersionFile, newVersion);
        
    var verChange = string.Format("Version changed from {0} to {1}", oldVersion, newVersion);
    Log.LogMessage(MessageImportance.High, verChange);
                        
    return true;
}
catch (Exception ex) {
    Log.LogError(string.Format("Failed to update central version file: {0}", ex.Message));
    return false;
}
    ]]></Code>
