  <UsingTask TaskName="FileUpdate" TaskFactory="RoslynCodeTaskFactory" AssemblyFile="$(MSBuildToolsPath)\Microsoft.Build.Tasks.Core.dll">
    <!--
       -  ___ _ _     _   _          _      _       
       - | __(_) |___| | | |_ __  __| |__ _| |_ ___ 
